<!DOCTYPE html>
<html lang="en">
<%- include('./partials/head') %>




<body>
  <%- include('./partials/header') %> 


  <section class="banner">
    <img src="img/img-home-banner.jpg" alt="Banner de ofertas">
  </section>
  
  <!--Inicio del main-->
  <main>
    <section class="last-visit">
      <h3 class="title">Basado en tu última visita</h3>

      <div class="products">
        <article class="card">
          <img src="img/img-cafetera-moulinex.jpg" alt="Cafetera" class="product_img">
          <div class="product-description">
            <i class="fas fa-truck"></i>
            <p class="prices">$6.770</p>
            <p class="discounts">40% off</p>
            <h4 class="descriptions">Cafetera Moulinex</h4>
          </div>
        </article>

        <article class="card">
          <img src="img/img-macbook-pro-2019.jpg" alt="MacBook" class="product_img">
          <div class="product-description">
            <i class="fas fa-truck"></i>
            <p class="prices">$230.000</p>
            <p class="discounts">20% off</p>
            <h4 class="descriptions">MacBook Pro 2019</h4>
          </div>
        </article>

        <article class="card">
          <img src="img/img-samsung-galaxy-s10.jpg" alt="Teléfono Móvil Samsung Galaxy" class="product_img">
          <div class="product-description">
            <i class="fas fa-truck"></i>
            <p class="prices">$70.500</p>
            <p class="discounts">10% off</p>
            <h4 class="descriptions">Samsung Galaxy S10</h4>
          </div>
        </article>

        <article class="card">
          <img src="img/img-tv-samsung-smart.jpg" alt="SmartTv Samsung" class="product_img">
          <div class="product-description">
            <i class="fas fa-truck"></i>
            <p class="prices">$23.200</p>
            <p class="discounts">5% off</p>
            <h4 class="descriptions">SmartTv Samsung 43"</h4>
          </div>
        </article>
      </div>
    </section>


    <section class="offers">
      <h3>Ofertas</h3>

      <div class="products">
        <article class="card">
          <img src="img/img-cafetera-moulinex.jpg" alt="Cafetera" class="product_img">
          <div class="product-description">
            <i class="fas fa-truck"></i>
            <p class="prices">$6.770</p>
            <p class="discounts">40% off</p>
            <h4 class="descriptions">Cafetera Moulinex</h4>
          </div>
        </article>

        <article class="card">
          <img src="img/img-macbook-pro-2019.jpg" alt="MacBook" class="product_img">
          <div class="product-description">
            <i class="fas fa-truck"></i>
            <p class="prices">$230.000</p>
            <p class="discounts">20% off</p>
            <h4 class="descriptions">MacBook Pro 2019</h4>
          </div>
        </article>

        <article class="card">
          <img src="img/img-samsung-galaxy-s10.jpg" alt="Teléfono Móvil Samsung Galaxy" class="product_img">
          <div class="product-description">
            <i class="fas fa-truck"></i>
            <p class="prices">$70.500</p>
            <p class="discounts">10% off</p>
          <h4 class="descriptions">Samsung Galaxy S10</h4>
          </div>
        </article>

        <article class="card">
          <img src="img/img-tv-samsung-smart.jpg" alt="SmartTv Samsung" class="product_img">
          <div class="product-description">
            <i class="fas fa-truck"></i>
            <p class="prices">$23.200</p>
            <p class="discounts">5% off</p>
            <h4 class="descriptions">SmartTv Samsung 43"</h4>
          </div>
        </article>
      </div>  
    </section>
  </main>
  <!--Final del main-->

  <%- include('./partials/footer') %> 
  

</body>
</html>